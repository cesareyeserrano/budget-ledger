{
  "name": "t-ledger",
  "version": "0.0.1-beta",
  "private": true,
  "description": "Ledger — app web de finanzas personales contra presupuesto (single-user, localStorage v1)",
  "scripts": {
    "dev": "next dev -p 3100",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db db-viewer",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger node scripts/migrate.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:backend": "playwright test --config playwright.backend.config.ts",
    "test:backend:full": "vitest run --reporter verbose && npm run test:e2e:backend"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-popover": "^1.1.21",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.19",
    "better-auth": "^1.6.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.474.0",
    "next": "^15.1.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "^19.2.8",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.8",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^3.0.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^12.0.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "overrides": {
    "sharp": "^0.35.0",
    "postcss": "$postcss",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
