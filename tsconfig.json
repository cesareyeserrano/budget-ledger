{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-buildcheck/types/**/*.ts",
    ".next-e2e-backend/types/**/*.ts",
    ".next-e2e/types/**/*.ts",
    ".next-sec/types/**/*.ts",
    ".next-smoke-be/types/**/*.ts",
    ".next-smoke/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-nodburl/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e"
  ]
}
