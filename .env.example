# feature backend — configuración por entorno (12-factor). Copia a .env.local y completa.
# NUNCA comitear .env* con valores reales (gitignore lo cubre; gitleaks lo verifica en CI).

# Postgres (fuente de verdad). Portátil: compose usa un volumen nombrado; gestionado usa su URL.
DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger

# Secreto de sesión de Better Auth (genera uno: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32

# Origen canónico de la app (para OAuth callbacks y CORS por defecto)
BETTER_AUTH_URL=http://localhost:3100

# Google OAuth (opcional en dev/test; REQUERIDO en production). El botón se deshabilita si faltan.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Orígenes permitidos para CORS, coma-separado. Por defecto: solo el origen de BETTER_AUTH_URL. Nunca '*'.
LEDGER_ALLOWED_ORIGINS=
